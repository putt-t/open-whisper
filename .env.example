DICTATION_BUNDLE_ID=com.example.dictation
DICTATION_CODESIGN_IDENTITY=-
DICTATION_SETTINGS_FILE="~/Library/Application Support/OpenWhisper/settings.json"

# Optional advanced overrides (usually leave unset):
# DICTATION_DEBUG_MODE=false
# DICTATION_PROJECT_ROOT=
# DICTATION_WHISPERKIT_ENDPOINT=http://127.0.0.1:50060/v1/audio/transcriptions
# DICTATION_ASR_TOKEN_FILE=~/.dictation/asr-token
# DICTATION_CLEANUP_PROVIDER=lmstudio
# DICTATION_LMSTUDIO_ENDPOINT=http://localhost:1234/v1/responses
# DICTATION_LMSTUDIO_MODEL=essentialai/rnj-1
# DICTATION_LMSTUDIO_TEMPERATURE=0.1
# DICTATION_LMSTUDIO_MAX_OUTPUT_TOKENS=96
